---
const features = [
  {
    tag: "DAEMON",
    name: "HEARTBEAT",
    description: "Autonomous background daemon that maintains persistent AI context across sessions. No manual intervention required.",
    flag: "--heartbeat"
  },
  {
    tag: "STORAGE",
    name: "MEMORY",
    description: "Persistent context storage with semantic search. Your AI remembers everything across conversations.",
    flag: "--memory"
  },
  {
    tag: "MODELS",
    name: "MULTI-MODEL",
    description: "Seamless switching between Claude, GPT, Gemini, and local models. One memory, any brain.",
    flag: "--model"
  },
  {
    tag: "PROTOCOL",
    name: "MCP-TOOLS",
    description: "Extensible tool system via Model Context Protocol. Add capabilities without modifying core.",
    flag: "--tools"
  },
  {
    tag: "CODE",
    name: "LSP",
    description: "Language Server Protocol integration for real-time code context. Your AI understands your codebase.",
    flag: "--lsp"
  },
  {
    tag: "SESSION",
    name: "MULTI-SESSION",
    description: "Run parallel AI sessions with shared or isolated memory contexts.",
    flag: "--session"
  }
];
---

<section class="py-24 px-6">
  <div class="max-w-5xl mx-auto">
    <div class="reveal mb-12 text-center">
      <h2 class="font-display text-3xl sm:text-4xl text-green phosphor-glow">&gt; SYSTEM CAPABILITIES</h2>
    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6 mt-12">
      {features.map((f, i) => (
        <div class={`reveal reveal-delay-${(i % 3) + 1} glass-panel p-6`}>
          <div class="font-mono text-xs text-green-dim tracking-widest mb-3">{f.tag}</div>
          <h3 class="font-display text-xl text-green mb-3">{f.name}</h3>
          <p class="font-body text-sm text-text leading-relaxed mb-4">{f.description}</p>
          <div class="font-mono text-xs text-green-dim">{f.flag}</div>
        </div>
      ))}
    </div>
  </div>
</section>
