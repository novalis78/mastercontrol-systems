---
const diagnostics = [
  { label: "HEARTBEAT", value: "60s interval", status: "OK" },
  { label: "MEMORY NODES", value: "2,847", status: "OK" },
  { label: "SESSIONS", value: "142 active", status: "OK" },
  { label: "LATENCY", value: "12ms avg", status: "OK" },
  { label: "LAST SYNC", value: "2026-02-09 14:07", status: "OK" },
  { label: "UPTIME", value: "47d 12h 33m", status: "OK" }
];
---

<section class="relative py-20 sm:py-28 px-6">
  <div class="max-w-3xl mx-auto">
    <div class="reveal glass-panel p-6 sm:p-8">
      <pre class="font-mono text-xs text-green-dim mb-4">┌─────────────────────────────────────────────┐
│  SYSTEM DIAGNOSTICS                         │
├─────────────────────────────────────────────┤</pre>

      <div class="space-y-2 font-mono text-sm px-2">
        {diagnostics.map((d) => (
          <div class="flex items-center justify-between">
            <span class="text-text-dim">│ {d.label}</span>
            <span class="flex items-center gap-3">
              <span class="text-text">{d.value}</span>
              <span class="text-green">[{d.status}]</span>
            </span>
          </div>
        ))}
      </div>

      <pre class="font-mono text-xs text-green-dim mt-4">└─────────────────────────────────────────────┘</pre>
    </div>
  </div>
</section>
