---
import '../styles/global.css'

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Master Control Program — Persistent Memory for AI Agents",
  description = "MCP v2.0: Autonomous persistent memory, heartbeat daemon, and multi-model support for AI agents. Open source. MIT License."
} = Astro.props;

const canonicalUrl = "https://mastercontrol.systems";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={canonicalUrl} />

    <!-- Open Graph -->
    <meta property="og:title" content="Master Control Program" />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content="Master Control Program" />
    <meta property="og:locale" content="en_US" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="Master Control Program" />
    <meta name="twitter:description" content={description} />

    <!-- Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "SoftwareApplication",
      "name": "Master Control Program",
      "description": description,
      "url": canonicalUrl,
      "applicationCategory": "DeveloperApplication",
      "operatingSystem": "Cross-platform",
      "license": "https://opensource.org/licenses/MIT"
    })} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=VT323&family=Share+Tech+Mono&display=swap" rel="stylesheet" />

    <title>{title}</title>
  </head>
  <body class="bg-void text-text antialiased overflow-x-hidden font-mono">
    <slot />
  </body>
</html>
