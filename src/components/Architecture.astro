      <h2 class="font-display text-3xl sm:text-4xl text-green phosphor-glow">&gt; ARCHITECTURE</h2>
    </div>

    <div class="grid md:grid-cols-2 gap-8">
      <!-- Panel 1: Heartbeat Mode -->
      <div class="reveal reveal-delay-1 glass-panel p-6 sm:p-8 overflow-x-auto">
        <h3 class="font-display text-lg text-green mb-4">HEARTBEAT MODE</h3>
        <pre class="font-mono text-xs sm:text-sm text-text leading-relaxed whitespace-pre">
  ┌─────────────────────────────┐
  │     HEARTBEAT DAEMON        │
  │  ┌───────┐    ┌──────────┐  │
  │  │ WATCH │───&gt;│ CONTEXT  │  │
  │  │ FILES │    │ BUILDER  │  │
  │  └───────┘    └────┬─────┘  │
  │                    │        │
  │              ┌─────▼──────┐ │
  │              │  MEMORY    │ │
  │              │  STORE     │ │
  │              └────────────┘ │
  └─────────────────────────────┘</pre>
      </div>

      <!-- Panel 2: Interactive Mode -->
      <div class="reveal reveal-delay-2 glass-panel p-6 sm:p-8 overflow-x-auto">
        <h3 class="font-display text-lg text-green mb-4">INTERACTIVE MODE</h3>
        <pre class="font-mono text-xs sm:text-sm text-text leading-relaxed whitespace-pre">
  ┌─────────────────────────────┐
  │     INTERACTIVE TUI         │
  │  ┌───────┐    ┌──────────┐  │
  │  │ USER  │───&gt;│   LLM    │  │
  │  │ INPUT │    │  ENGINE   │  │
  │  └───────┘    └────┬─────┘  │
  │                    │        │
  │  ┌──────────┐ ┌────▼─────┐  │
  │  │ MCP      │ │ RESPONSE │  │
  │  │ TOOLS    │ │ STREAM   │  │
  │  └──────────┘ └──────────┘  │
  └─────────────────────────────┘</pre>
      </div>
    </div>
  </div>
</section>
