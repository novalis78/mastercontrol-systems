---
---

<section class="py-24 px-6 bg-screen">
  <div class="max-w-2xl mx-auto">
    <div class="reveal mb-12 text-center">
      <h2 class="font-display text-3xl sm:text-4xl text-green phosphor-glow">&gt; INSTALLATION</h2>
    </div>

    <div class="space-y-6">
      <!-- Homebrew (recommended) -->
      <div class="reveal reveal-delay-1 glass-panel p-6">
        <p class="font-mono text-xs text-text-dim mb-3"># Homebrew (recommended)</p>
        <div class="space-y-1 font-mono text-sm">
          <p><span class="text-green-dim">$</span> <span class="text-green">brew tap mastercontrol/mcp</span></p>
          <p><span class="text-green-dim">$</span> <span class="text-green">brew install mastercontrol</span></p>
        </div>
      </div>

      <!-- pip -->
      <div class="reveal reveal-delay-2 glass-panel p-6">
        <p class="font-mono text-xs text-text-dim mb-3"># pip</p>
        <div class="font-mono text-sm">
          <p><span class="text-green-dim">$</span> <span class="text-green">pip install mastercontrol</span></p>
        </div>
      </div>

      <!-- From source -->
      <div class="reveal reveal-delay-3 glass-panel p-6">
        <p class="font-mono text-xs text-text-dim mb-3"># From source</p>
        <div class="space-y-1 font-mono text-sm">
          <p><span class="text-green-dim">$</span> <span class="text-green">git clone git@github.com:decima-systems/mastercontrol.git</span></p>
          <p><span class="text-green-dim">$</span> <span class="text-green">cd mastercontrol && pip install -e .</span></p>
        </div>
      </div>
    </div>
  </div>
</section>
