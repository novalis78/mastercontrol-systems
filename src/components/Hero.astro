---
---

<section class="relative min-h-screen flex items-center justify-center overflow-hidden">
  <!-- TRON grid floor -->
  <div class="tron-grid absolute inset-0 pointer-events-none" aria-hidden="true"></div>

  <!-- Content -->
  <div class="relative z-10 flex flex-col items-center justify-center text-center px-6 max-w-4xl mx-auto">
    <!-- ASCII MCP Logo -->
    <div class="mb-8 opacity-0" style="animation: fade-in 1s ease forwards 0.3s;">
      <pre class="font-display text-green text-xs sm:text-sm md:text-base leading-tight phosphor-glow inline-block text-left">
     ███╗   ███╗ ██████╗██████╗
     ████╗ ████║██╔════╝██╔══██╗
     ██╔████╔██║██║     ██████╔╝
     ██║╚██╔╝██║██║     ██╔═══╝
     ██║ ╚═╝ ██║╚██████╗██║
     ╚═╝     ╚═╝ ╚═════╝╚═╝     </pre>
    </div>

    <!-- Typewriter title -->
    <div class="mb-4 opacity-0" style="animation: fade-in 0.5s ease forwards 0.8s;">
      <h1 class="font-display text-2xl sm:text-4xl md:text-5xl text-green phosphor-glow">
        <span class="inline-block overflow-hidden whitespace-nowrap border-r-2 border-green" style="animation: typing 2s steps(32) 1s forwards, cursor-blink 0.7s step-end infinite;">
          &gt; MASTER CONTROL PROGRAM v2.0
        </span>
      </h1>
    </div>

    <!-- Subtitle -->
    <p class="font-body text-lg text-text mb-6 opacity-0" style="animation: fade-in 1s ease forwards 2s;">
      &gt; Persistent memory for autonomous AI agents
    </p>

    <!-- Status line -->
    <div class="flex flex-wrap items-center justify-center gap-4 sm:gap-6 font-mono text-sm text-text-dim mb-8 opacity-0" style="animation: fade-in 1s ease forwards 2.4s;">
      <span>[STATUS: <span class="text-green">ONLINE</span>]</span>
      <span>[MEMORY: <span class="text-green">ACTIVE</span>]</span>
      <span>[UPTIME: <span class="text-green">99.97%</span>]</span>
    </div>

    <!-- Glass panel CTA -->
    <div class="glass-panel inline-block px-6 py-3 mt-8 opacity-0" style="animation: fade-in 1s ease forwards 2.8s;">
      <code class="font-mono text-sm sm:text-base">
        <span class="text-green-dim">$</span> <span class="text-green">pip install mastercontrol</span>
      </code>
    </div>
  </div>
</section>
